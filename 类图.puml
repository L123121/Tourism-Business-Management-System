@startuml 旅游业务管理系统类图
skinparam classAttributeIconSize 0

class 旅游路线 {
    - 路线代码 : String
    - 路线名称 : String
    - 路线描述 : String
    - 创建日期 : Date
    - 状态 : 路线状态
    + 添加旅游活动()
    + 取消路线()
    + 获取旅游活动列表() : List<TourActivity>
}

class 旅游活动 {
    - 活动代码 : String
    - 活动名称 : String
    - 活动描述 : String
    + 创建旅游团()
    + 获取旅游团列表() : List<TourGroup>
}

class 旅游团 {
    - 团代码 : String
    - 出发日期 : Date
    - 截止日期 : Date
    - 人数限额 : int
    - 当前人数 : int
    - 状态 : 团状态
    + 可以申请() : boolean
    + 增加人数(n: int)
    + 获取价格() : Price
}

class 价格 {
    - 大人价格 : double
    - 小孩价格 : double
    - 优惠措施 : String
    - 是否已公开 : boolean
    + 公开价格()
    + 计算总价(大人: int, 小孩: int) : double
}

class 申请 {
    - 申请编号 : String
    - 申请日期 : Date
    - 状态 : 申请状态
    + 办理申请()
    + 取消申请()
    + 计算订金() : double
    + 计算取消手续费() : double
    + 获取参加者列表() : List<Participant>
}

class 申请责任人 {
    - 姓名 : String
    - 电话 : String
    + 获取申请信息() : Application
}

class 参加者 {
    - 姓名 : String
    - 性别 : String
    - 年龄 : int
    - 类型 : 参加者类型
    + 修改信息()
    + 取消参加()
}

class 支付记录 {
    - 支付编号 : String
    - 金额 : double
    - 支付日期 : Date
    - 支付类型 : 支付类型
    + 获取支付详情()
}

class 收据 {
    - 收据编号 : String
    - 金额 : double
    - 开具日期 : Date
    + 打印收据()
}

class 变更历史 {
    - 变更编号 : String
    - 变更日期 : Date
    - 变更内容 : String
    - 操作人 : String
}

enum 路线状态 {
    活跃
    已取消
}

enum 团状态 {
    未开放
    已开放
    已截止
    已完成
}

enum 申请状态 {
    进行中
    已完成
    已取消
}

enum 参加者类型 {
    大人
    小孩
}

enum 支付类型 {
    订金
    余款
    退款
}

旅游路线 "1" -- "*" 旅游活动 : 包含 >
旅游路线 "1" -- "*" 变更历史 : 记录 >
旅游路线 .. 路线状态

旅游活动 "1" -- "*" 旅游团 : 组织 >

旅游团 "1" -- "1" 价格 : 关联 >
旅游团 "1" -- "*" 申请 : 接受 >
旅游团 .. 团状态

申请 "1" -- "1" 申请责任人 : 属于 >
申请 "1" -- "*" 参加者 : 包含 >
申请 "1" -- "*" 支付记录 : 包含 >
申请 "1" -- "*" 收据 : 生成 >
申请 .. 申请状态

参加者 .. 参加者类型
支付记录 .. 支付类型

@enduml
